# ── Ollama ──────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
MODEL=qwen2.5:7b
NPM_REGISTRY=https://registry.npmmirror.com/
OLLAMA_TIMEOUT=180
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=768
OLLAMA_TEMPERATURE=0.05
RSSHUB_BASE_URL=http://localhost:1200

# ── Database ────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/finai.db

# ── News Collection ─────────────────────────────────────
COLLECT_INTERVAL_SECONDS=5
MAX_NEWS_AGE_HOURS=24
AUTO_ANALYZE_FLASH=true
AUTO_ANALYSIS_MAX_PENDING=3
LIVE_MARKET_QUOTES=true
MARKET_QUOTE_EXACT_PRICES=false
MARKET_QUOTE_TIMEOUT_SECONDS=4

# ── AI Analysis ─────────────────────────────────────────
ALERT_SCORE_THRESHOLD=7
ANALYSIS_LANGUAGE=zh

# ── Portfolio ───────────────────────────────────────────
# Format: TICKER:NAME:QTY, comma-separated
# MY_POSITIONS=600519.SH:贵州茅台:100,00700.HK:腾讯:200,NVDA:英伟达:50

# ── Telegram ────────────────────────────────────────────
TG_BOT_TOKEN=
TG_CHAT_ID=

# ── Discord ─────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Server ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8888
DEBUG=false
